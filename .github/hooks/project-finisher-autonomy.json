{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node ./.github/scripts/session-start-context.mjs",
        "timeout": 20
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node ./.github/scripts/stop-summary-guard.mjs",
        "timeout": 20
      }
    ]
  }
}
