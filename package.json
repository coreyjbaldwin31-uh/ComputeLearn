{
  "name": "computelearn-platform",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run lint && npm run type-check && npm run test && npm run build",
    "docker:build": "docker build -t computelearn-platform .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "api:test": "newman run tests/api/smoke.postman_collection.json"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.46.0",
    "@vercel/otel": "^2.1.1",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^29.0.1",
    "newman": "^6.2.2",
    "prisma": "^6.19.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
