# ComputeLearn — Production environment variables
# Copy to .env.production and fill in all REQUIRED values before deploying.
#
#   cp .env.production.template .env.production

# ── Runtime ──────────────────────────────────────────────────────────

# REQUIRED — Must be "production" for production builds
NODE_ENV=production

# Port the app listens on (default: 3000)
PORT=3000

# Bind address inside the container
HOSTNAME=0.0.0.0

# Disable Next.js anonymous telemetry
NEXT_TELEMETRY_DISABLED=1

# ── Database ─────────────────────────────────────────────────────────

# REQUIRED — PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Used by docker-compose.prod.yml to configure the Postgres container
POSTGRES_USER=computelearn
POSTGRES_PASSWORD=
POSTGRES_DB=computelearn

# ── Authentication ───────────────────────────────────────────────────

# REQUIRED — Random secret for signing tokens. Generate with: npx auth secret
AUTH_SECRET=

# REQUIRED — Google OAuth credentials from console.cloud.google.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# REQUIRED — Canonical URL of the deployed application (no trailing slash)
# Example: https://app.computelearn.com
NEXTAUTH_URL=

# ── Monitoring ───────────────────────────────────────────────────────

# Sentry project DSN (optional, but recommended)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Environment tag sent to Sentry
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Trace sampling rate: 0.0–1.0 (default: 0.1 = 10% of requests)
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0

# Enable verbose Sentry logging (0 or 1)
SENTRY_DEBUG=0
NEXT_PUBLIC_SENTRY_DEBUG=0

# OpenTelemetry service name
OTEL_SERVICE_NAME=ComputeLearn

# ── LTI 1.3 (optional) ──────────────────────────────────────────────

LTI_PLATFORM_URL=
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
LTI_AUTH_ENDPOINT=
LTI_TOKEN_ENDPOINT=
