# ComputeLearn — local environment variables
# Copy to .env before running: cp .env.example .env

# Runtime mode — default to development for local use; production builds should set this explicitly
NODE_ENV=development

# Port the app listens on inside the container
PORT=3000

# Bind address — 0.0.0.0 so the container is reachable from the host
HOSTNAME=0.0.0.0

# Disable Next.js anonymous telemetry
NEXT_TELEMETRY_DISABLED=1

# Database
DATABASE_URL=postgresql://computelearn:localdev@localhost:5432/computelearn

# Auth.js (NextAuth v5)
AUTH_SECRET=  # Generate with: npx auth secret
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_DEBUG=0
NEXT_PUBLIC_SENTRY_DEBUG=0
OTEL_SERVICE_NAME=ComputeLearn

# LTI 1.3 Configuration (Canvas)
LTI_PLATFORM_URL=
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
LTI_AUTH_ENDPOINT=
LTI_TOKEN_ENDPOINT=
LTI_JWKS_URL=

# Application URL used for LTI redirect URIs (server-side only)
APP_URL=http://localhost:3000
